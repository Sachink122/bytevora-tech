## Database
# Example: postgres://user:password@localhost:5432/agency
DATABASE_URL=
POSTGRES_URL=
STORAGE_URL=

## Server
AUTH_API_PORT=4000
AUTH_ALLOWED_ORIGINS=http://localhost:5173
AUTH_COOKIE_SECURE=false

## JWT / Admin
AUTH_JWT_SECRET=change-this-secret-in-production
AUTH_REFRESH_SECRET=
AUTH_TOKEN_EXPIRY=8h
AUTH_REFRESH_EXPIRY=7d
AUTH_REFRESH_COOKIE_NAME=agency_refresh_token
AUTH_ACCESS_COOKIE_NAME=agency_access_token

## Admin credentials (used as fallback/default admin)
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_NAME=Admin User
AUTH_ADMIN_ROLE=Admin

# Optional: enable SSL to Postgres (true/false)
PG_SSL=false
