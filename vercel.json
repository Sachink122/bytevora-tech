{
  "builds": [
    {
      "src": "backend/server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server/server.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "frontend/$1"
    }
  ]
}